.page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.08);
}

.hero {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.95;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.item:last-child {
  border-bottom: none;
}

.item-main {
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
}

.item-meta {
  font-size: 24rpx;
  color: #475569;
  margin-top: 4rpx;
}

.action-btn {
  align-self: center;
  background: #0f766e !important;
  color: #ffffff !important;
  border-radius: 999rpx;
}

.food-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.food-tag {
  font-size: 24rpx;
  color: #115e59;
  background: #ccfbf1;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.empty {
  color: #64748b;
  font-size: 24rpx;
}

.plan-item {
  border-top: 1rpx solid #e2e8f0;
  padding-top: 16rpx;
  margin-top: 16rpx;
}

.plan-row {
  display: flex;
  gap: 14rpx;
}

.plan-index {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #0f766e;
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.plan-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary {
  margin-top: 18rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #94a3b8;
  color: #0f172a;
  font-size: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
